# Скопируй этот файл в .env и заполни своими значениями:
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=gymlog_db
POSTGRES_USER=gymlog_user
POSTGRES_PASSWORD=придумай_надёжный_пароль

# ── Django ────────────────────────────────────────────────────
SECRET_KEY=сгенерируй_50_символов_python_-c_"import_secrets;print(secrets.token_urlsafe(50))"
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── AI-провайдер ─────────────────────────────────────────────
# deepseek (дефолт) | mock (без ключа, для разработки)
LLM_PROVIDER=deepseek

# DeepSeek — platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
